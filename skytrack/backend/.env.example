PORT=3001

# OpenSky Network credentials (optional - anonymous access has lower rate limits)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Postgres (optional - enables flight history)
DATABASE_URL=postgresql://user:password@localhost:5432/skytrack

# Anthropic API key (optional - enables AI natural language search)
ANTHROPIC_API_KEY=sk-ant-...

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
