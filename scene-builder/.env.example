# Copy to .env.local and fill in values

# For local dev AI commands (proxied through Vite dev server, never sent to browser)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare Worker URL (leave empty to use the built-in Vite dev proxy)
# VITE_WORKER_URL=https://scene-builder-worker.<your-subdomain>.workers.dev
